# Supabase project URL, e.g. https://xxxx.supabase.co
SUPABASE_URL=

# Server-side scripts should use the service role key (keep secret; never commit .env)
SUPABASE_SERVICE_ROLE_KEY=

# Alternatively for read-only / client-side use:
# SUPABASE_ANON_KEY=

# Optional: enable auto-download of artifacts from Supabase Storage on app start
SUPABASE_BUCKET=
# Optional folder prefix inside the bucket (example: runs/2026-04-19)
SUPABASE_ARTIFACT_PREFIX=
